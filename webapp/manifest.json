					"controlId": "mainContents",
					"parent": "master"
				},
				"salesorderlist":{
					"viewId": "salesorderlist",
					"viewName": "Sales/SalesOrderList",
					"controlId": "mainContents",
					"parent": "master"
				},
				"salesorder":{
					"viewId": "salesorder",
					"viewName": "Sales/SalesOrder",
					"controlId": "mainContents",
					"parent": "master"
				},
				"salesdeliverylist":{
					"viewId": "salesdeliverylist",
					"viewName": "Sales/SalesDeliveryList",
					"controlId": "mainContents",
					"parent": "master"
				},
				"salesdelivery":{
					"viewId": "salesdelivery",
					"viewName": "Sales/SalesDelivery",
					"controlId": "mainContents",
					"parent": "master"
				},
				"salesinvoicelist":{
					"viewId": "salesinvoicelist",
					"viewName": "Sales/SalesInvoiceList",
					"controlId": "mainContents",
					"parent": "master"
				},
				"salesinvoice":{
					"viewId": "salesinvoice",
					"viewName": "Sales/SalesInvoice",
					"controlId": "mainContents",
					"parent": "master"
				},
				"manageapplication": {
					"viewId": "manageapplication",
					"viewName": "Application/ManageApplication",
					"controlId": "mainContents",
					"parent": "companymaster"
				},
				"usermanagement": {
					"viewId": "usermanagement",
					"viewName": "UserManagement",
					"controlId": "mainContents",
					"parent": "companymaster"
				},
				"licensemanagement": {
					"viewId": "licensemanagement",
					"viewName": "CompanySettings/LicenseManagement",
					"controlId": "mainContents",
					"parent": "companymaster"
				},
				"importmasters": {
					"viewId": "importmasters",
