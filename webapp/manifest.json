				},
				"pageshortcutkey": {
					"viewId": "pageshortcutkey",
					"viewName": "ApplicationSettings/PageShortcutKeys",
					"controlId": "mainContents",
					"parent": "companymaster"
				},
				"chome": {
					"viewId": "chome",
					"viewName": "Chome",
					"controlId": "mainContents",
					"parent": "companymaster"
				},
				"companymaster": {
					"viewId": "companymaster",
