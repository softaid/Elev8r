
<mvc:View
controllerName="sap.ui.elev8rerp.componentcontainer.controller.Home"
xmlns="sap.m"
xmlns:f="sap.f"
xmlns:mvc="sap.ui.core.mvc"
xmlns:core="sap.ui.core"
xmlns:tnt="sap.tnt"
xmlns:l="sap.ui.layout">
	<f:FlexibleColumnLayout  id="fclCommonDashboard" backgroundDesign="Solid">
		<f:beginColumnPages>
			<f:DynamicPage showFooter="true" toggleHeaderOnTitleClick="false">
				<f:title>
					<f:DynamicPageTitle>
						<f:heading>
							<Title id="DashboardTitle" text="Dashboard" />
						</f:heading>

						<f:actions>
							<ToolbarSpacer/>
						</f:actions>

					</f:DynamicPageTitle>
				</f:title>
				<f:content>
					<Page class="pgDashboard" showHeader="false" id="contentDashboard">
						<content>
							<GenericTile class="sapUiTinyMarginBegin sapUiTinyMarginTop tileLayout" header="Total Leads" press="on_Over_Due_Detail">
								<TileContent footer="">
									<NumericContent truncateValueTo="20" value="30" valueColor="Good" withMargin="false" />
								</TileContent>
							</GenericTile>
							<GenericTile class="sapUiTinyMarginBegin sapUiTinyMarginTop tileLayout" header="Live Projects" press="get_Purchase_invoice">
								<TileContent footer="">
									<NumericContent truncateValueTo="20" value="10" valueColor="Good" withMargin="false" />
								</TileContent>
							</GenericTile>
							<GenericTile class="sapUiTinyMarginBegin sapUiTinyMarginTop tileLayout" header="Open Activities" press="get_revenue_press">
								<TileContent footer="">
									<NumericContent truncateValueTo="20" value="20" valueColor="Good" withMargin="false" />
								</TileContent>
							</GenericTile>
							<GenericTile class="sapUiTinyMarginBegin sapUiTinyMarginTop tileLayout" header="Overdue Activities" press="get_expenses_press">
								<TileContent unit="" footer="">
									<NumericContent truncateValueTo="20" value="5" valueColor="Error" withMargin="false" />
								</TileContent>
							</GenericTile>
						</content>		
					</Page>
				</f:content>
			</f:DynamicPage>
		</f:beginColumnPages>
	</f:FlexibleColumnLayout>
</mvc:View>
