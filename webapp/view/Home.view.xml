					</f:DynamicPageTitle>
				</f:title>
				<f:content>
					<Page class="pgDashboard" showHeader="false" id="contentDashboard">
						<content>
							<GenericTile class="sapUiTinyMarginBegin sapUiTinyMarginTop tileLayout" header="Total Leads" press="redirectTo('addlead')">
								<TileContent footer="">
