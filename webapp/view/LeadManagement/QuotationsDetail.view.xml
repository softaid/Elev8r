<mvc:View
	xmlns:c="sap.ui.core"
	controllerName="sap.ui.elev8rerp.componentcontainer.controller.LeadManagement.QuotationsDetail"
	xmlns:mvc="sap.ui.core.mvc"
	xmlns:u="sap.ui.unified"
	xmlns="sap.m"
	xmlns:t="sap.ui.table"
	xmlns:f="sap.f"
	xmlns:layout="sap.ui.layout"
	xmlns:form="sap.ui.layout.form"
    xmlns:core="sap.ui.core"
	height="100%">
		
	<f:DynamicPage preserveHeaderStateOnScroll="true" headerExpanded="{/headerExpanded}">
		<f:title>
			<f:DynamicPageTitle>
				<f:heading>
					<Title text="{i18n>quotationDetailTitle}"/>
				</f:heading>
				<f:actions>
					<ToolbarSpacer/>
					<Button
						text="{i18n>saveButtonText}"
                        type="Emphasized"
						press="onSave"
						id="btnSave"/>
				    <Button
						text="{i18n>deleteButtonText}"
						type="Emphasized"
						id="btnDelete"
						press="onDelete"/>						
				</f:actions>
				<f:navigationActions>
					<Button
						icon="sap-icon://decline"
						type="Transparent" press="onCancel" />
				</f:navigationActions>
			</f:DynamicPageTitle>
		</f:title>
		<f:content>				
   			<form:Form editable="true">
                <form:title>
                </form:title>
                <form:layout>
                    <form:ResponsiveGridLayout
                        labelSpanXL="4"
                        labelSpanL="4"
                        labelSpanM="4"
                        labelSpanS="12"
                        adjustLabelSpan="false"
                        emptySpanXL="0"
                        emptySpanL="0"
                        emptySpanM="0"
                        emptySpanS="0"
                        columnsXL="3"
                        columnsL="2"
                        columnsM="2"
                        singleContainerFullSize="false" />
                </form:layout>
                <form:formContainers>
                    <form:FormContainer>
					    <form:formElements> 
                            <form:FormElement label="{i18n>quotationDetailLiftType}">
                                <form:fields>
                                    <Select id="lifttype"
					                    required="true" 
                                        change=""
                                        selectedKey="{editQuotationModel>/lifttypeid}" 
                                        forceSelection="false"
                                        width="500px"
                                        items="{
                                            path: 'liftTypeModel>/modelData',
                                            sorter: { path: 'id' }
                                        }">
                                        <core:Item key="{liftTypeModel>id}" text="{liftTypeModel>description}" />
                                    </Select>
                                </form:fields>
                            </form:FormElement>
                             <form:FormElement label="{i18n>quotationDetailLead}">
                                <form:fields>
                                    <Select id="lead"
					                    required="true" 
                                        change=""
                                        selectedKey="{editQuotationModel>/leadid}" 
                                        forceSelection="false"
                                        width="500px"
                                        items="{
                                            path: 'leadModel>/modelData',
                                            sorter: { path: 'id' }
                                        }">
                                        <core:Item key="{leadModel>id}" text="{leadModel>leadname}" />
                                    </Select>
                                </form:fields>
                            </form:FormElement>
                            <form:FormElement label="{i18n>quottionDetailContact}">
                                <form:fields>
                                    <Select id="contact"
					                    required="true" 
                                        change=""
                                        selectedKey="{editQuotationModel>/contactid}" 
                                        forceSelection="false"
                                        width="500px"
                                        items="{
                                            path: 'contactModel>/modelData',
                                            sorter: { path: 'id' }
                                        }">
                                        <core:Item key="{contactModel>id}" text="{contactModel>contactname}" />
                                    </Select>
                                </form:fields>
                            </form:FormElement>
                            <form:FormElement label="{i18n>quotationDetailQuoteValue}">
                                <form:fields>
                                    <Input id="quotevalue" valueLiveUpdate="true" value="{editQuotationModel>/quotevalue}"  required="true" change="onPartyNameChange"/>
                                </form:fields>
                            </form:FormElement> 
                            <form:FormElement label="{i18n>quotationDetailNoOfLifts}">
                                <form:fields>
                                    <Input id="nooflifts" valueLiveUpdate="true" value="{editQuotationModel>/nooflifts}"  required="true" change="onPartyNameChange"/>
                                </form:fields>
                            </form:FormElement>   
                            <form:FormElement label="{i18n>quottionDetailQuoteStage}">
                                <form:fields>
                                    <Select id="stageid"
					                    required="true" 
                                        change=""
                                        selectedKey="{editQuotationModel>/quotestageid}" 
                                        forceSelection="false"
                                        width="500px"
                                        items="{
                                            path: 'quoteStageModel>/modelData',
                                            sorter: { path: 'id' }
                                        }">
                                        <core:Item key="{quoteStageModel>id}" text="{quoteStageModel>description}" />
                                    </Select>
                                </form:fields>
                            </form:FormElement>
                        </form:formElements>
                    </form:FormContainer>
                </form:formContainers>
            </form:Form>
		</f:content>
	</f:DynamicPage>
</mvc:View>
