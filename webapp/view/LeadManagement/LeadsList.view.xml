<core:View displayBlock="true" controllerName="sap.ui.elev8rerp.componentcontainer.controller.LeadManagement.LeadsList" height="100%"
    xmlns="sap.m"
    xmlns:f="sap.f"
    xmlns:core="sap.ui.core"
    xmlns:layout="sap.ui.layout"
	xmlns:form="sap.ui.layout.form"
    xmlns:u="sap.ui.unified">
    <f:FlexibleColumnLayout  id="fclLead" backgroundDesign="Solid">
		<f:beginColumnPages>
		    <f:DynamicPage toggleHeaderOnTitleClick="false">
			    <f:title>
		    	    <f:DynamicPageTitle>
				        <f:heading>
					       <Title text=" "/>
				        </f:heading>
			        </f:DynamicPageTitle>
		        </f:title>
				<f:content>	
                        <VBox fitContainer="true">
                         <Panel id="pnlLeadMaster" expandable="true" expanded="true"  headerText="Lead List" width="auto">
               	<form:Form editable="true">
                        <form:title>
                        </form:title>
                        <form:layout>
                            <form:ResponsiveGridLayout
                                labelSpanXL="4"
                                labelSpanL="4"
                                labelSpanM="4"
                                labelSpanS="12"
                                adjustLabelSpan="true"
                                emptySpanXL="0"
                                emptySpanL="0"
                                emptySpanM="0"
                                emptySpanS="0"
                                columnsXL="3"
                                columnsL="2"
                                columnsM="1"
                                singleContainerFullSize="true" />
                        </form:layout>
                        <form:formContainers>
                            <form:FormContainer  width="auto"> 
                                <form:formElements>
                                  <form:FormElement label="Lead Status">
                                    <form:fields>
                                        <SegmentedButton accessibleName="Select Lead Status" selectionChange="handleSelectionChange">
                                            <items>
                                                <SegmentedButtonItem icon="map" text="All Leads (100)"></SegmentedButtonItem>
                                                <SegmentedButtonItem icon="map" text="Qualified Leads (80)"></SegmentedButtonItem>
                                                <SegmentedButtonItem icon="map" text="Un Qualified Leads  (20)"></SegmentedButtonItem>
                                            </items>
                                        </SegmentedButton>
                                    </form:fields>
                                    </form:FormElement>   

                                   <form:FormElement label="Lead Type">
                                    <form:fields>
                                        <SegmentedButton accessibleName="Select Lead Type" selectionChange="handleSelectionChange">
                                            <items>
                                                <SegmentedButtonItem icon="map" text="All Leads (100)"></SegmentedButtonItem>
                                                <SegmentedButtonItem icon="map" text="B2B"></SegmentedButtonItem>
                                                <SegmentedButtonItem icon="map" text="B2C"></SegmentedButtonItem>
                                            </items>
                                        </SegmentedButton>
                                    </form:fields>
                                    </form:FormElement>   
                                  <form:FormElement label="Lead Category">
                                    <form:fields>
                                        <SegmentedButton accessibleName="Select Lead Category" selectionChange="handleSelectionChange">
                                            <items>
                                                <SegmentedButtonItem icon="map" text="Commercial"></SegmentedButtonItem>
                                                <SegmentedButtonItem icon="map" text="Residential"></SegmentedButtonItem>
                                            </items>
                                        </SegmentedButton>
                                    </form:fields>
                                    </form:FormElement>   
                                  </form:formElements>      
                </form:FormContainer>
                </form:formContainers>
                </form:Form>               
              </Panel>
                        <Table id="tblPartyMaster" 
                                inset="false"
                                sticky="ColumnHeaders" growing="true" growingThreshold="10" growingScrollToLoad="true"  
                                items="{
                                path: 'LeadsMasterModel>/modelData',
                                sorter: {
                                    path: 'hatchername'
                                }
                            }">
                            <headerToolbar>
                                <Toolbar>
                                    <content>
                                        <Title text="" level="H2"/>
                                        <ToolbarSpacer />

                                          <SearchField search="onSearch" width="17.5rem" id = "onSearchId"/>
                                          <Button icon="sap-icon://sort" type="Transparent" press="sort"/>

                                        	<!-- <Button
                                                tooltip="Sort"
                                                icon="sap-icon://sort"
                                                press="handleSortButtonPressed"/>
                                            <Button
                                                tooltip="Filter"
                                                icon="sap-icon://filter"
                                                press="handleFilterButtonPressed"/>
                                            <Button
                                                tooltip="Group"
                                                icon="sap-icon://group-2"
                                                press="handleGroupButtonPressed"/>
                                        <Button icon="sap-icon://add" type="Transparent" press="onAddNew"/> -->
                                        <Button
                                        text="Upload template"
                                        type="Emphasized"
                                        press="onUploadMasterData" id="btnUploadData"/>
                                    </content>
                                </Toolbar>
                            </headerToolbar>
                            <!-- <infoToolbar>
                            <OverflowToolbar id="vsdFilterBar" visible="false">
                                <Text id="vsdFilterLabel" />
                            </OverflowToolbar>
                            </infoToolbar> -->
                            <columns>
                                <Column><Text text ="{i18n>leadId}" /></Column>
                                <Column minScreenWidth="Tablet" demandPopin="true"><Text text ="Lead Type"/></Column>   
                                <Column minScreenWidth="Tablet" demandPopin="true"><Text text ="Lead Category"/></Column>     
                                <Column><Text text ="{i18n>leadNameLabel}" /></Column>
                                <Column minScreenWidth="Tablet" demandPopin="true"><Text text ="{i18n>leadSourceLabel}"/></Column>
                                <Column minScreenWidth="Tablet" demandPopin="true"><Text text ="Site Location"/></Column>      
                                <Column minScreenWidth="Tablet" demandPopin="true"><Text text ="Email W"/></Column>
                                <Column minScreenWidth="Tablet" demandPopin="true"><Text text ="Sales REP"/></Column>
                                <Column minScreenWidth="Tablet" demandPopin="true"><Text text ="Mobile Work"/></Column>
                                <Column minScreenWidth="Tablet" demandPopin="true"><Text text ="Lead Stage"/></Column>      
                                   
                            </columns>
                            <items>
                                <ColumnListItem type="Navigation" press="onListItemPress">
                                    <cells>
                                    <ObjectIdentifier text="{LeadsMasterModel>id}" />
                                        <Text text="{LeadsMasterModel>leadtype}" />
                                        <Text text="{LeadsMasterModel>leadscategory}" />
                                        <Text text="{LeadsMasterModel>leadname}" />
                                        <Text text="{LeadsMasterModel>sourcename}"/>
                                        <Text text="{LeadsMasterModel>locationname}"/>
                                        <Text text="{LeadsMasterModel>email}"/>
                                        <Text text="{LeadsMasterModel>salesrep}"/>
                                        <Text text="{LeadsMasterModel>mobileno}"/> 
                                        <Text text="{LeadsMasterModel>stagename}"/> 
                                    </cells>
                                </ColumnListItem>
                            </items>
                        </Table>
                        <VBox id="pnlErrMessage" visible="false" class="sapMMsgStrip sapMMsgStripError sapUiSmallMarginBottom" width="auto">
                        </VBox >
                        <TabContainer id="pnlDataTabs" visible="false" showAddNewButton="false" class="pnlDataTabs sapUiResponsiveContentPadding">
                            <items></items>
                        </TabContainer>
                        <HBox width="auto"></HBox>
                        <HBox id="pnlMasterData" width="auto"></HBox>
                    </VBox> 
                </f:content>				
			</f:DynamicPage>
		</f:beginColumnPages>
	</f:FlexibleColumnLayout>
</core:View>