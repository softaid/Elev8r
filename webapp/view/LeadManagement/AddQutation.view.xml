
<mvc:View
	xmlns:c="sap.ui.core"
	controllerName="sap.ui.elev8rerp.componentcontainer.controller.LeadManagement.AddQutation"
	xmlns:mvc="sap.ui.core.mvc"
	xmlns:u="sap.ui.unified"
	xmlns="sap.m"
	xmlns:t="sap.ui.table"
	xmlns:f="sap.f"
    xmlns:core="sap.ui.core"
	xmlns:layout="sap.ui.layout"
	xmlns:form="sap.ui.layout.form"
	height="100%">
	<f:DynamicPage preserveHeaderStateOnScroll="true" headerExpanded="{/headerExpanded}">
		<f:title>
			<f:DynamicPageTitle>
                <f:heading>
                    <Title text="Create Quotation"/>
                </f:heading>
                <f:actions>
                    <ToolbarSpacer/>
                        <Button
                        text="{i18n>saveButtonText}"
                        id="btnSave"
                        type="Emphasized"
                        press = "onSave"/>
                </f:actions>
                <f:navigationActions>
                    <Button
                            icon="sap-icon://decline"
                            type="Transparent" press="onCancel" />
                </f:navigationActions>
            </f:DynamicPageTitle>
        </f:title>
		<f:content>	
            <VBox> 
                <Panel id="pnlShedMaster" expandable="true" expanded="true"  headerText="Qutation Details" width="auto">
                    <form:Form editable="true">
                        <form:title>
                        </form:title>
                        <form:layout>
                            <form:ResponsiveGridLayout
                                labelSpanXL="4"
                                labelSpanL="4"
                                labelSpanM="4"
                                labelSpanS="12"
                                adjustLabelSpan="false"
                                emptySpanXL="0"
                                emptySpanL="0"
                                emptySpanM="0"
                                emptySpanS="0"
                                columnsXL="3"
                                columnsL="2"
                                columnsM="1"
                                singleContainerFullSize="false" />
                        </form:layout>
                        <form:formContainers>
                            <form:FormContainer title="Quotation Details" width="100%"> 
                                <form:formElements>
                                    <form:FormElement label="Quotation Type">
                                        <form:fields>
                                            <Select id="txtQutationType"
                                                required="true" 
                                                change=""
                                                selectedKey="{editQutationModel>/quotetype}" 
                                                forceSelection="true"
                                                width="500px"
                                                items="{
                                                    path: 'quoteTypeModel>/modelData',
                                                    sorter: { path: 'id' }
                                                }">
                                                <core:Item key="{quoteTypeModel>id}" text="{quoteTypeModel>description}" />
                                            </Select>
                                        </form:fields>
                                    </form:FormElement>
                                    <form:FormElement label="Quotation Date">
                                        <form:fields>
                                            <DatePicker id="createddate" width="100%" 
                                            placeholder="{config>/dateFormat/placeholder}"
                                            displayFormat="{config>/dateFormat/displayFormat}"
                                            value="{editQutationModel>/quotedate}"
                                            valueFormat="dd/MM/yyyy"
                                            required="true"  
                                            />
                                        </form:fields>
                                    </form:FormElement>
                                    <form:FormElement label="Quotation ID">
                                        <form:fields>
                                            <Input id="quotationid" valueLiveUpdate="true" value="{editQutationModel>/quotename}"  required="true" />
                                        </form:fields>
                                    </form:FormElement>
                                    <form:FormElement label="Quotation Name">
                                        <form:fields>
                                            <Input id="txtQutationName" valueLiveUpdate="true" value="{editQutationModel>/quotename}"  required="true" />
                                        </form:fields>
                                    </form:FormElement>   
                                    <form:FormElement label="Quotation Description">
                                        <form:fields>
                                            <Input id="txtQutationDescription" valueLiveUpdate="true" value="{editQutationModel>/quotediscription}"  required="true" change="onPartyNameChange"/>
                                        </form:fields>
                                    </form:FormElement>  
                                    <form:FormElement label="{i18n>leadContactPerson}">
                                        <form:fields>
                                            <Input id="contactPerson" editable="false" valueLiveUpdate="true" value="{editQutationModel>/contactperson}"  required="true" change="onPartyNameChange"/>
                                        </form:fields>
                                    </form:FormElement>
                                    <form:FormElement label="Win Probability">
                                        <form:fields>
                                            <!-- <Input id="progress" valueLiveUpdate="true" value="{editLeadActivityModel>/progress}" required="true"/> -->
                                            <Slider width="100%" class="customInputHeight" enableTickmarks="true" id="inpWarningLevel"
                                                max="100" min="0" progress="true"
                                                showAdvancedTooltip="true" value="{editLeadActivityModel>/progress}">
                                                <ResponsiveScale id="rScaleWarningLevel"
                                                    tickmarksBetweenLabels="20" />
                                            </Slider>
                                        </form:fields>
                                    </form:FormElement> 
                                    <form:FormElement label="Quotation Status">
                                        <form:fields>
                                            <Select id="txtstatus"
                                                required="true" 
                                                change=""
                                                selectedKey="{editQutationModel>/quotestatusid}" 
                                                forceSelection="true"
                                                width="500px"
                                                items="{
                                                    path: 'QuoteStatusModel>/modelData',
                                                    sorter: { path: 'id' }
                                                }">
                                                <core:Item key="{QuoteStatusModel>id}" text="{QuoteStatusModel>description}" />
                                            </Select>
                                        </form:fields>
                                    </form:FormElement>
                                    <form:FormElement label="Quote Score">
                                        <form:fields>
                                            <Input id="quotescore" valueLiveUpdate="true" value="{editQutationModel>/quotevalue}"  required="true" change="onPartyNameChange"/>
                                        </form:fields>
                                    </form:FormElement>
                                    <form:FormElement label="Lead Source">
                                        <form:fields>
                                            <Select id="leadsourceid"
                                                required="true" 
                                                change=""
                                                selectedKey="{editQutationModel>/leadsourceid}" 
                                                forceSelection="true"
                                                width="500px"
                                                items="{
                                                    path: 'QuoteStatusModel>/modelData',
                                                    sorter: { path: 'id' }
                                                }">
                                                <core:Item key="{QuoteStatusModel>id}" text="{QuoteStatusModel>description}" />
                                            </Select>
                                        </form:fields>
                                    </form:FormElement>
                                    <form:FormElement label="Quotation Value">
                                        <form:fields>
                                            <Input id="txtQutationValue" valueLiveUpdate="true" value="{editQutationModel>/quotevalue}"  required="true" change="onPartyNameChange"/>
                                        </form:fields>
                                    </form:FormElement>
                                    <form:FormElement label="Quote Stage">
                                        <form:fields>
                                            <Select id="stageid"
                                                required="true" 
                                                change=""
                                                editable="false"
                                                selectedKey="{editQutationModel>/stageid}" 
                                                forceSelection="true"
                                                width="500px"
                                                items="{
                                                    path: 'stageModel>/modelData',
                                                    sorter: { path: 'id' }
                                                }">
                                                <core:Item key="{stageModel>id}" text="{stageModel>description}" />
                                            </Select>
                                        </form:fields>
                                    </form:FormElement>
                                    <form:FormElement label="{i18n>leadArchitect}">
                                        <form:fields>
                                            <Select id="landarchitectid"
                                                required="true" 
                                                change=""
                                                editable="false"
                                                selectedKey="{editQutationModel>/architectidid}" 
                                                forceSelection="true"
                                                width="500px"
                                                items="{
                                                    path: 'leadCntCategoryModel>/modelData',
                                                    sorter: { path: 'id' }
                                                }">
                                                <core:Item key="{leadCntCategoryModel>id}" text="{leadCntCategoryModel>description}" />
                                            </Select>
                                        </form:fields>
                                    </form:FormElement>
                                    <form:FormElement label="{i18n>leadConsultant}">
                                        <form:fields>
                                            <Select id="landconsaltantid"
                                                required="true" 
                                                change=""
                                                editable="false"
                                                selectedKey="{editQutationModel>/leadconsaltantid}" 
                                                forceSelection="true"
                                                width="500px"
                                                items="{
                                                    path: 'leadCntTypeModel>/modelData',
                                                    sorter: { path: 'id' }
                                                }">
                                                <core:Item key="{leadCntTypeModel>id}" text="{leadCntTypeModel>description}" />
                                            </Select>
                                        </form:fields>
                                    </form:FormElement>
                                    <form:FormElement label="Category">
                                        <form:fields>
                                            <Select id="txtCategory"
                                                required="true" 
                                                change=""
                                                selectedKey="{editQutationModel>/quotecategory}" 
                                                forceSelection="true"
                                                width="500px"
                                                items="{
                                                    path: 'QuoteCategoryModel>/modelData',
                                                    sorter: { path: 'id' }
                                                }">
                                                <core:Item key="{QuoteCategoryModel>id}" text="{QuoteCategoryModel>description}" />
                                            </Select>
                                        </form:fields>
                                    </form:FormElement>
                                    <form:FormElement label="SubCategory">
                                        <form:fields>
                                            <Select id="txtSubCategory"
                                                required="true" 
                                                change=""
                                                selectedKey="{editQutationModel>/quotesubcategory}" 
                                                forceSelection="true"
                                                width="500px"
                                                items="{
                                                    path: 'QuoteSubCategoryModel>/modelData',
                                                    sorter: { path: 'id' }
                                                }">
                                                <core:Item key="{QuoteSubCategoryModel>id}" text="{QuoteSubCategoryModel>description}" />
                                            </Select>
                                        </form:fields>
                                    </form:FormElement>
                                </form:formElements>
                            </form:FormContainer>
                        </form:formContainers>
                    </form:Form>
                    <form:Form editable="true"> 
                        <form:title>
                        </form:title>
                        <form:layout>
                            <form:ResponsiveGridLayout
                                labelSpanXL="4"
                                labelSpanL="4"
                                labelSpanM="4"
                                labelSpanS="12"
                                adjustLabelSpan="false"
                                emptySpanXL="0"
                                emptySpanL="0"
                                emptySpanM="0"
                                emptySpanS="0"
                                columnsXL="3"
                                columnsL="2"
                                columnsM="1"
