                                        <form:fields>
                                            <Select id="typesofdoorid"                                             
                                                change=""
                                                selectedKey="{editQutationModel>/typeofdoorid}" 
                                                forceSelection="true"
                                                width="500px"
                                                items="{
                                                    path: 'leadDoorTypeModel>/modelData'                                                
                                                }">
                                                <core:Item key="{leadDoorTypeModel>id}" text="{leadDoorTypeModel>description}" />
                                            </Select>
                                        </form:fields>
                                    </form:FormElement>
                                    <form:FormElement label="{i18n>leadLandingDoors}">
                                        <form:fields>
                                            <Select id="landingdoorsid"                                             
                                                change=""
                                                selectedKey="{editQutationModel>/landingdoorid}" 
                                                forceSelection="true"
                                                width="500px"
                                                items="{
                                                    path: 'landingDoorModel>/modelData'                                                
                                                }">
                                                <core:Item key="{landingDoorModel>id}" text="{landingDoorModel>description}" />
                                            </Select>
                                        </form:fields>
                                    </form:FormElement>
                                    <form:FormElement label="{i18n>leadCarDoor}">
                                        <form:fields>
                                            <Select id="leadcarid"                                             
