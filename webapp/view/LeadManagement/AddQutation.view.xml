                                                }">
                                                <core:Item key="{standaredFloorHeightModel>id}" text="{standaredFloorHeightModel>description}" />
                                            </Select>
                                        </form:fields>
                                    </form:FormElement>
                                    <form:FormElement label="Stop">
                                        <form:fields>
                                            <Input id="txtstopid"  type="number" valueLiveUpdate="true" value="{editQutationModel>/stopsid}"/>
                                        </form:fields>
                                    </form:FormElement>
                                    <form:FormElement label="{i18n>laedLowestFloorMarking}">
                                        <form:fields>
                                            <Select id="landingfloorsid"                                             
