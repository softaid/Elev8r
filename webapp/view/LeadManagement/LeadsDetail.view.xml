            <l:Grid containerQuery="true" class="sapUiSmallMarginTop">
                <TileContent footer="Address - Parvati Apt., AB Chowk, Pune - 28" class="sapUiSmallMargin">
                    <NewsContent contentText="Lead Name - Lead 1                    "
                        subheader="Company - LogicalDNA Technosystems Pvt Ltd, Pune" />
                </TileContent>
                <TileContent footer="August 21, 2013" class="sapUiSmallMargin">
                    <NewsContent contentText="SAP Unveils Powerful New Player Comparison Tool Exclusively on NFL.com"
                        subheader="SAP News" />
                </TileContent>
            </l:Grid>

            <IconTabBar id ="idIconTabBar" selectedKey="{view>/selectedTabKey}" expanded="{= !${device>/system/phone} }" expandable="{device>/system/phone}" class="sapUiResponsiveContentPadding" select="onTabSelect">
                <items>
                    <IconTabFilter text="History" key="activity">
                        <ScrollContainer
                            height="100%"
                            width="100%"
                            horizontal="true"
                            vertical="true"
                            focusable="true">
                            <List
                                id="activityList"
                                items="{ path: 'activityModel>/modelData' }">
                                <StandardListItem
                                    
                                    info="{activityModel>subject}"
                                    description="{activityModel>createddate}"
                                    title="{activityModel>status}"
                                    type="Navigation"
                                    press="tileDetail" />
                            </List>
                        </ScrollContainer>
                    </IconTabFilter>

                    <IconTabFilter text="Lift Details" key="liftdetails">
                        <ScrollContainer
                            height="100%"
                            width="100%"
                            horizontal="true"
                            vertical="true"
                            focusable="true">
                            <List
                                id="liftList"
                                items="{ path: 'liftModel>/modelData' }">
                                <StandardListItem
                                    
                                    info="Lift Type - {liftModel>typeoflift}"
                                    description="Qty - {liftModel>nooflifts}"
                                    title="Capacity - {liftModel>capacity}"
                                    type="Navigation"
                                    press="tileDetail" />
                            </List>
                        </ScrollContainer>
                    </IconTabFilter>    

                    <IconTabFilter text="Quotation" key="quotation">
                        <ScrollContainer
                            height="100%"
                            width="100%"
                            horizontal="true"
                            vertical="true"
                            focusable="true">
                            <List
                                id="quotationList"
                                items="{ path: 'liftModel>/modelData' }">
                                <StandardListItem
                                    
                                    info="Lift Type - {liftModel>typeoflift}"
                                    description="Qty - {liftModel>nooflifts}"
                                    title="Capacity - {liftModel>capacity}"
                                    type="Navigation"
                                    press="tileDetail" />
                            </List>
                        </ScrollContainer>
                    </IconTabFilter>

                    <IconTabFilter text="Files" key="files">
                        <ScrollContainer
                            height="100%"
                            width="100%"
                            horizontal="true"
                            vertical="true"
                            focusable="true">
                            <List
                                id="fileList"
                                items="{ path: 'liftModel>/modelData' }">
                                <StandardListItem
                                    
                                    info="Lift Type - {liftModel>typeoflift}"
                                    description="Qty - {liftModel>nooflifts}"
                                    title="Capacity - {liftModel>capacity}"
                                    type="Navigation"
                                    press="tileDetail" />
                            </List>
                        </ScrollContainer>
                    </IconTabFilter>      
                </items>
            </IconTabBar>
        </content>
	</Page>
</mvc:View>
