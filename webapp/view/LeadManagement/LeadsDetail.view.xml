<mvc:View
	controllerName="sap.ui.elev8rerp.componentcontainer.controller.LeadManagement.LeadsDetail"
	xmlns="sap.m"
    xmlns:f="sap.f"
	xmlns:core="sap.ui.core"
	xmlns:card="sap.f.cards"
	xmlns:mvc="sap.ui.core.mvc"
	xmlns:layout="sap.ui.layout"
	xmlns:form="sap.ui.layout.form">

	<Page class="pgDashboard" showHeader="false" >
        <content>
            <HBox>
                <VBox width="100%">
                    <f:Card class="sapUiMediumMargin">
                        <f:header class="tileBox">
                            <card:Header class="cardStyle" title="Lead Name - {leadModel>/leadname}" subtitle="Company Name - {leadModel>/companyname}" />
                        </f:header>
                        <f:content>
                            <TextArea value="Address - {leadModel>/address}" width="100%"/>
                        </f:content>
                    </f:Card>
                </VBox>
                <VBox width="100%">
                    <f:Card class="sapUiMediumMargin">
                        <f:header class="tileBox">
                            <card:Header title="Contact Person - {leadModel>/contacterson}" subtitle="Email - {leadModel>/email}" />
                        </f:header>
                        <f:content>
                            <TextArea value="Mobile - {leadModel>/mobileno}" width="100%"/>
                        </f:content>
                    </f:Card>
                </VBox>
            </HBox>
            <IconTabBar id ="idIconTabBar" selectedKey="{view>/selectedTabKey}" expanded="{= !${device>/system/phone} }" expandable="{device>/system/phone}" class="sapUiResponsiveContentPadding" select="onTabSelect">
                <items>
                    <IconTabFilter icon="sap-icon://history" text="History" key="activity">
                        <ScrollContainer
                            height="100%"
                            width="100%"
                            horizontal="true"
                            vertical="true"
                            focusable="true">
                            <List
                                id="activityList"
                                items="{ path: 'activityModel>/modelData' }">
                                <StandardListItem
                                    
                                    info="{activityModel>subject}"
                                    description="{activityModel>createddate}"
                                    title="{activityModel>status}"
                                    type="Inactive" />
                            </List>
                        </ScrollContainer>
                    </IconTabFilter>

                    <IconTabFilter icon="sap-icon://customer-and-supplier" text="Lift Details" key="liftdetails">
                        <form:Form editable="true">
                            <form:title>
                            </form:title>
                            <form:layout>
                                <form:ResponsiveGridLayout
                                    labelSpanXL="4"
                                    labelSpanL="4"
                                    labelSpanM="4"
                                    labelSpanS="12"
                                    adjustLabelSpan="false"
                                    emptySpanXL="0"
                                    emptySpanL="0"
                                    emptySpanM="0"
                                    emptySpanS="0"
                                    columnsXL="3"
                                    columnsL="2"
                                    columnsM="1"
                                    singleContainerFullSize="false" />
                            </form:layout>
                            <form:formContainers>
                                <form:formContainer>
                                    <form:formElements>                            
                                        <form:FormElement label="{i18n>leadDetailTypeofLift}">
                                            <form:fields>
                                                <Input id="lftType" value="{liftModel>/typeoflift}" ebabled="false"/>
                                            </form:fields>
                                        </form:FormElement>
                                        <form:FormElement label="{i18n>leadDetailLiftCapacity}">
                                            <form:fields>
                                                <Input id="capacity" value="{liftModel>/capacity}"  enabled="false"/>
                                            </form:fields>
                                        </form:FormElement>  
                                        <form:FormElement label="{i18n>leadDetailLiftModel}">
                                            <form:fields>
                                                <Input id="model" value="{liftModel>/model}" enabled="false" />
                                            </form:fields>
                                        </form:FormElement>
                                        <form:FormElement label="{i18n>leadDetailLiftMachine}">
                                            <form:fields>
                                                <Input id="machine" value="{liftModel>/machine}" enabled="false" />
                                            </form:fields>
                                        </form:FormElement>
                                        <form:FormElement label="{i18n>leadDetailsFloorHeight}">
                                            <form:fields>
                                                <Input id="txtmobileNo" value="{liftModel>/floorheight}" enabled="false" />
                                            </form:fields>
                                        </form:FormElement>
                                        <form:FormElement label="{i18n>leadDetailsConsultant}">
                                            <form:fields>
                                                <Input id="consultant" value="{LiftModel>/consultant}" enabled="false" />
                                            </form:fields>
                                        </form:FormElement>                                        
                                        <form:FormElement label="{i18n>leadDetailsArchitect}">
                                            <form:fields>
                                                <Input id="architect" value="{LiftModel>/architect}" enabled="false" />
                                            </form:fields>
                                        </form:FormElement>   
                                    </form:formElements>
                                </form:formContainer>
                            </form:formContainers>
                        </form:Form>
                    </IconTabFilter>    

                    <IconTabFilter icon="sap-icon://sales-quote" text="Quotation" key="quotation">
                        <ScrollContainer
                            height="100%"
                            width="100%"
                            horizontal="true"
                            vertical="true"
                            focusable="true">
                            <List
                                id="quotationList"
                                items="{ path: 'liftModel>/modelData' }">
                                <StandardListItem
                                    
                                    info="Lift Type - {liftModel>typeoflift}"
                                    description="Qty - {liftModel>nooflifts}"
                                    title="Capacity - {liftModel>capacity}"
                                    type="Inactive" />
                            </List>
                        </ScrollContainer>
                    </IconTabFilter>

                    <IconTabFilter icon="sap-icon://sap-box" text="Files" key="files">
                        <ScrollContainer
                            height="100%"
                            width="100%"
                            horizontal="true"
                            vertical="true"
                            focusable="true">
                            <List
                                id="fileList"
                                items="{ path: 'liftModel>/modelData' }">
                                <StandardListItem
                                    
                                    info="Lift Type - {liftModel>typeoflift}"
                                    description="Qty - {liftModel>nooflifts}"
                                    title="Capacity - {liftModel>capacity}"
                                    type="Inactive" />
                            </List>
                        </ScrollContainer>
                    </IconTabFilter>      
                </items>
            </IconTabBar>
        </content>
	</Page>
</mvc:View>
