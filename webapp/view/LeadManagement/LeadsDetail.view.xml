	controllerName="sap.ui.elev8rerp.componentcontainer.controller.LeadManagement.Details"
	xmlns="sap.m"
	xmlns:tnt="sap.tnt"
	xmlns:l="sap.ui.layout"
	xmlns:core="sap.ui.core"
	xmlns:card="sap.f.cards"
	xmlns:plugins="sap.ui.table.plugins"
	xmlns:common="sap.ui.commons"
	xmlns:mvc="sap.ui.core.mvc">

	<Page class="pgDashboard" showHeader="false" >
        <content>
