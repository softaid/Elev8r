<mvc:View
	controllerName="sap.ui.elev8rerp.componentcontainer.controller.ProjectManagement.ProjectManagementFile"
	xmlns:table="sap.ui.table"
	xmlns:mvc="sap.ui.core.mvc"
	xmlns:u="sap.ui.unified"
	xmlns:c="sap.ui.core"
	xmlns="sap.m"
    height="100%">
	<Page
		showHeader="false"
		enableScrolling="false"
		class="sapUiContentPadding">
		<content>
			<table:Table
				rows="{/ProductCollection}"
				selectionMode="MultiToggle"
				visibleRowCount="7"
				paste="onPaste"
				ariaLabelledBy="title">
				<table:extension>
					<OverflowToolbar style="Clear">
						<Title id="title" text="Products"/>
					</OverflowToolbar>
				</table:extension>
				<table:columns>
					<table:Column width="11rem">
						<Label text="Product Name" />
						<table:template>
							<Text text="{Name}" wrapping="false" />
						</table:template>
					</table:Column>
					<table:Column width="11rem">
						<Label text="Product Id" />
						<table:template>
							<Input value="{ProductId}"/>
						</table:template>
					</table:Column>
					<table:Column width="6rem" hAlign="End">
						<Label text="Quantity" />
						<table:template>
							<Label text="{Quantity}" />
						</table:template>
					</table:Column>
					<table:Column width="9rem">
						<Label text="Status" />
						<table:template>
							<ObjectStatus text="{Status}" state="{
								path: 'Available',
								formatter: '.formatAvailableToObjectState'
							}"/>
						</table:template>
					</table:Column>
					<table:Column width="9rem">
						<Label text="Price" />
						<table:template>
							<u:Currency value="{Price}" currency="{CurrencyCode}"/>
						</table:template>
					</table:Column>
					<table:Column width="12rem">
						<Label text="Supplier" />
						<table:template>
							<ComboBox value="{SupplierName}" items="{/Suppliers}">
								<c:Item text="{Name}"/>
							</ComboBox>
						</table:template>
					</table:Column>
					<table:Column width="9rem">
						<Label text="Image" />
						<table:template>
							<m:Link text="Show Image" href="{ProductPicUrl}" target="_blank"/>
						</table:template>
					</table:Column>
					<table:Column width="9rem">
						<Label text="Details" />
						<table:template>
							<Button text="Show Details" press="handleDetailsPress"/>
						</table:template>
					</table:Column>
					<table:Column width="7rem">
						<Label text="Heavy Weight" />
						<table:template>
							<CheckBox selected="{
								path: 'Heavy',
								type: 'sap.ui.model.type.String'
							}"/>
						</table:template>
					</table:Column>
					<table:Column width="12rem">
						<Label text="Main Category" />
						<table:template>
							<Select selectedKey="{Category}" items="{/Categories}">
								<c:Item text="{Name}" key="{Name}"/>
							</Select>
						</table:template>
					</table:Column>
					<table:Column width="12rem">
						<Label text="Additional Categories" />
						<table:template>
							<MultiInput
								tokenUpdate="updateMultipleSelection"
								value="{AdditionalCategory}"
								tokens="{AdditionalCategoriesSelection}"
								suggestionItems="{
									path: '/Categories',
									sorter: { path: 'Name' }
								}"
								showValueHelp="false"
								>
								<tokens>
									<Token key="{Key}" text="{Name}"/>
								</tokens>
								<suggestionItems>
									<c:Item key="{ProductId}" text="{Name}" />
								</suggestionItems>
							</MultiInput>
						</table:template>
					</table:Column>
					<table:Column width="6rem" hAlign="Center">
						<Label text="Status" />
						<table:template>
							<c:Icon src="{
								path: 'Available',
								formatter: '.formatAvailableToIcon'
							}"/>
						</table:template>
					</table:Column>
					<table:Column width="11rem" hAlign="Center">
						<Label text="Delivery Date" />
						<table:template>
							<DatePicker value="{
								path: 'DeliveryDate',
								type: 'sap.ui.model.type.Date',
								formatOptions: {source: {pattern: 'timestamp'}}
							}"/>
						</table:template>
					</table:Column>
				</table:columns>
			</table:Table>
		</content>
	</Page>
</mvc:View>